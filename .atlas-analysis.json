  "keyFeatures": [
    "Persistent memory with SQLite + FTS5 full-text search",
    "Knowledge graph with typed relations between observations",
    "Adaptive change pipeline with 12 flow variants",
    "Clarity Gate with 8-dimension ambiguity analysis",
    "Business rules extraction using BRG taxonomy",
    "Reverse-engineer existing codebases into SDD artifacts",
    "Spec-aware code review against requirements and business rules",
    "38 MCP tools + 6 on-demand prompts",
    "Hot/Cold instruction architecture for token efficiency",
    "Wave assignments for parallel task execution"
  ],
  "publicApiSurface": [
    "hoofy serve - Start MCP server",
    "hoofy update - Update to latest version",
    "mem_save - Save observation to memory",
    "mem_search - Full-text search across sessions",
    "mem_context - Recent observations for session startup",
    "mem_relate - Create typed relation between observations",
    "mem_build_context - Traverse knowledge graph",
    "sdd_change - Create adaptive change pipeline",
    "sdd_context_check - Mandatory conflict scanner",
    "sdd_change_advance - Advance to next pipeline stage",
    "sdd_init_project - Initialize greenfield project",
    "sdd_clarify - Run Clarity Gate",
    "sdd_reverse_engineer - Scan existing codebase",
    "sdd_bootstrap - Write SDD artifacts",
    "sdd_explore - Pre-pipeline context capture",
    "sdd_suggest_context - Ad-hoc context recommendation",
    "sdd_review - Spec-aware code review",
    "sdd_adr - Capture Architecture Decision Records",
    "sdd_create_business_rules - Extract business rules from requirements",
    "sdd_create_tasks - Generate task breakdown with dependencies"
  ]
}
